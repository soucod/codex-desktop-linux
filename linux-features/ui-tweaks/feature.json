{
  "id": "ui-tweaks",
  "title": "UI Tweaks",
  "description": "Optional UI customization patches for ChatGPT Desktop for Linux.",
  "defaultEnabled": false,
  "entrypoints": {
    "patchDescriptors": "./patch.js",
    "stageHook": "./stage.sh",
    "cleanupHook": "./cleanup.sh"
  },
  "tweaks": {
    "appearance": {
      "dockIcon": {
        "enabled": false
      }
    },
    "modelPicker": {
      "showModelsByDefault": {
        "enabled": true
      }
    },
    "reasoning": {
      "keepEffortLabelsEnglish": {
        "enabled": true
      }
    },
    "sidebar": {
      "projectName": {
        "enabled": true,
        "style": "font-weight: 700 !important; padding-top: 0.25rem;"
      }
    }
  }
}
