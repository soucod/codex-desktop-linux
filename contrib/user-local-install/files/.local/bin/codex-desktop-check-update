#!/usr/bin/env bash
set -euo pipefail

source "${HOME}/.local/opt/codex-desktop-linux/lib/codex-desktop-linux/common.sh"

ensure_layout
load_install_config
load_metadata

build_head="${REPO_HEAD-}"
if [ -z "$build_head" ]; then
    build_head="$(current_repo_head)"
fi
source_head="$(source_repo_head 2>/dev/null || true)"
if [ -z "$source_head" ]; then
    source_head="${SOURCE_REPO_HEAD-}"
fi
source_overlay_sha="$(source_repo_overlay_signature 2>/dev/null || true)"
remote_head=""
dmg_headers=""

if ! remote_head="$(remote_repo_head 2>/dev/null)"; then
    echo "Could not query wrapper repo upstream."
    exit 1
fi

if ! dmg_headers="$(remote_dmg_headers 2>/dev/null)"; then
    echo "Could not query Codex.dmg headers."
    exit 1
fi

remote_etag="$(header_value "$dmg_headers" "etag")"
remote_last_modified="$(header_value "$dmg_headers" "last-modified")"
remote_content_length="$(header_value "$dmg_headers" "content-length")"

repo_changed=0
dmg_changed=0
repo_upstream_changed=0
repo_overlay_changed=0

if [ "$build_head" != "$remote_head" ]; then
    repo_changed=1
    repo_upstream_changed=1
fi

if [ "$source_overlay_sha" != "${SOURCE_OVERLAY_SHA256-}" ]; then
    repo_changed=1
    repo_overlay_changed=1
fi

if [ "${DMG_ETAG-}" != "$remote_etag" ] || [ "${DMG_LAST_MODIFIED-}" != "$remote_last_modified" ] || [ "${DMG_CONTENT_LENGTH-}" != "$remote_content_length" ]; then
    dmg_changed=1
fi

echo "Install root: $OPT_ROOT"
echo "Source repo:  $SOURCE_REPO_DIR"
echo "Build repo:   ${REPO_DIR:-$(effective_repo_dir)}"
echo "Build repo head:     $build_head"
echo "Source repo head:    ${source_head:-unavailable}"
echo "Wrapper repo remote: $remote_head"
echo "Source overlay sha:  ${source_overlay_sha:-none}"
echo "Cached DMG etag:     ${DMG_ETAG-untracked}"
echo "Remote DMG etag:     ${remote_etag:-unknown}"
echo "Cached DMG modified: ${DMG_LAST_MODIFIED-untracked}"
echo "Remote DMG modified: ${remote_last_modified:-unknown}"

if [ "$repo_changed" -eq 0 ] && [ "$dmg_changed" -eq 0 ]; then
    echo "Status: up to date"
    exit 0
fi

echo "Status: update available"
if [ "$repo_upstream_changed" -eq 1 ]; then
    echo "Reason: wrapper repo upstream changed"
fi
if [ "$repo_overlay_changed" -eq 1 ]; then
    echo "Reason: source overlay changed"
fi
if [ "$dmg_changed" -eq 1 ]; then
    echo "Reason: Codex.dmg changed"
fi
exit 10
